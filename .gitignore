# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# TextMate grammar artifacts are produced by `npm run fetch-grammar` from
# tinymist's published VSIX — they are build output, not source.
src/assets/grammar/*.json
!src/assets/grammar/.gitkeep

# Monaco runtime assets (oniguruma WASM + theme JSONs) are mirrored into
# public/vendor/ by `npm run fetch-monaco-assets` from node_modules — build
# output, not source.
public/vendor/

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Code metrics tool output (VS Code Counter extension)
.VSCodeCounter/

# Local git worktrees (isolated dev workspaces)
.worktrees/

# Agent / tool scratch dirs (never commit)
.codex-temp/
.playwright-cli/
.playwright-mcp/

# Agent-generated session state, plans, and design notes — local-only.
.omc/
docs/superpowers/
