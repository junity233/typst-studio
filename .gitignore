# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# TextMate grammar artifacts are produced by `npm run fetch-grammar` from
# tinymist's published VSIX — they are build output, not source.
src/assets/grammar/*.json
!src/assets/grammar/.gitkeep

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Code metrics tool output (VS Code Counter extension)
.VSCodeCounter/

# Local git worktrees (isolated dev workspaces)
.worktrees/
