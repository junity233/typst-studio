{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Typst Studio",
  "version": "0.1.0",
  "identifier": "com.typststudio.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": false,
    "windows": [
      {
        "title": "Typst Studio",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 500
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "Typst Studio",
    "category": "DeveloperTool",
    "shortDescription": "A Typst visual editor with live SVG preview.",
    "longDescription": "Typst Studio is a native desktop Typst editor: a Monaco code editor on the left and a real-time SVG preview on the right. It embeds the official typst compiler (typst, typst-svg, typst-pdf, typst-render, typst-kit) directly in a Tauri 2 + Rust backend for millisecond-level incremental compilation, with full PDF and PNG export.",
    "copyright": "MIT OR Apache-2.0",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [],
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "10.15"
    },
    "windows": {
      "wix": null,
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "linux": {
      "deb": {
        "depends": []
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  }
}
