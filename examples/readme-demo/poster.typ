  fill: rgb("#f7f0e8"),
)
#set text(font: ("Aptos", "Segoe UI", "Noto Sans CJK SC"), fill: rgb("#2c241d"))

#align(center)[
  #v(0.9cm)
  #text(size: 25pt, weight: "bold", fill: rgb("#8a3b12"))[Typst Studio]
